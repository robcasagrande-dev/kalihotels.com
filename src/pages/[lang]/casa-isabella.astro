  "/images/uploads/2023/05/casa-isabella-01-31.jpg",
  "/images/uploads/2023/05/casa-isabella-01-29.jpg"
];

// Construct JSON-LD Structured Data
const baseUrl = `https://kalihotels.com/${lang}/casa-isabella/`;
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Hotel",
    "@id": baseUrl + "#hotel",
    "name": "Casa de Isabella",
    "description": t.seo.casa_isabella.description,
    "url": baseUrl,
    "image": [
      "https://kalihotels.com/images/uploads/2023/05/casa-isabella-01-03-1024x683.jpg",
      "https://kalihotels.com/images/uploads/2023/05/casa-isabella-home.jpg"
    ],
    "telephone": "+57 300 111 2222",
    "email": "reservas.kalihotels@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Calle 19 #2-80",
      "addressLocality": "Santa Marta",
      "addressRegion": "Magdalena",
      "postalCode": "470004",
      "addressCountry": "CO"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "11.2411",
      "longitude": "-74.2010"
    },
    "priceRange": "$$$",
    "starRating": {
      "@type": "Rating",
      "ratingValue": "5"
    },
    "checkinTime": "14:00",
    "checkoutTime": "12:00",
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Private Rooftop Pool", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Courtyard Garden", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Air Conditioning", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Free WiFi", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "24-hour front desk", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Curated Art Collection", "value": true }
    ],
    "award": "TripAdvisor Travelers' Choice Award",
    "sameAs": [
      "https://www.instagram.com/kalihotels",
      "https://www.facebook.com/kalihotels"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Kali Hotels", "item": `https://kalihotels.com/${lang}/` },
      { "@type": "ListItem", "position": 2, "name": "Casa de Isabella", "item": baseUrl }
    ]
  }
];
---

<BaseLayout 
  title={t.seo.casa_isabella.title} 
  description={t.seo.casa_isabella.description} 
  lang={lang} 
  ogImage="/images/uploads/2023/05/casa-isabella-01-03-1024x683.jpg"
  ogType="website"
  schema={schema}
>
  <!-- Property Hero -->
  <section class="property-hero">
    <div class="hero-overlay"></div>
    <img src="/images/uploads/2023/05/casa-isabella-01-03-1024x683.jpg" alt="Casa Isabella Banner" class="hero-img" />
    <div class="hero-text container text-center">
      <h1 class="property-title">{t.properties.casa_isabella.title}</h1>
      <p class="property-subtitle">{t.properties.casa_isabella.subtitle}</p>
    </div>
  </section>

  <!-- Main Info Block -->
  <section class="property-details container">
    <div class="details-grid">
      <div class="details-text">
        <h2 class="section-title">The Sanctuary</h2>
        {t.properties.casa_isabella.paragraphs.map(p => (
          <p class="desc-p">{p}</p>
        ))}
        
        <div class="quick-facts">
          <div class="fact-item">
            <strong>Location:</strong>
            <span>Centro Histórico, Santa Marta</span>
          </div>
          <div class="fact-item">
            <strong>Atmosphere:</strong>
            <span>Colonial Grandeur & Contemporary Luxury</span>
          </div>
          <div class="fact-item">
            <strong>Highlights:</strong>
            <span>Tropical Courtyard, Private Pool, Curated Art</span>
          </div>
        </div>
      </div>

      <div class="details-sidebar glass">
        <h3>{t.booking.title}</h3>
        <p>Book directly with us to get access to exclusive room options and benefits.</p>
        <a href="https://wubook.net/nneb/mprop?f=today&n=1&ep=4e454d97&w_id=4791&h=isabella" target="_blank" rel="noopener noreferrer" class="btn-gold booking-btn">
          {t.booking.search}
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="property-gallery container">
    <h2 class="section-title text-center mb-5">Gallery</h2>
    <Gallery images={galleryImages} />
  </section>

  <!-- Contact & Info -->
  <section class="property-contact container">
    <div class="contact-grid glass">
      <div class="contact-item">
        <h4>{t.properties.contact_info.phone}</h4>
        <p>+57 300 111 2222</p>
      </div>
      <div class="contact-item">
        <h4>{t.properties.contact_info.email}</h4>
        <p><a href="mailto:isabella@kalihotels.com">isabella@kalihotels.com</a></p>
      </div>
      <div class="contact-item">
        <h4>{t.properties.contact_info.address}</h4>
        <p>Calle 19 #2-80, Centro Histórico, Santa Marta, Colombia</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .property-hero {
    position: relative;
    height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(11, 12, 16, 0.4) 0%, rgba(11, 12, 16, 0.85) 100%);
    z-index: 2;
  }

  .hero-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-text {
    position: relative;
    z-index: 3;
    padding-top: 80px;
  }

  .property-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--text-main);
    margin-bottom: 1rem;
  }

  .property-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--text-muted);
    font-family: var(--font-body);
  }

  .text-center {
    text-align: center;
  }

  .mb-5 {
    margin-bottom: 3rem;
  }

  /* Details Grid */
  .property-details {
    padding: 6rem 2rem;
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .details-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .desc-p {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .quick-facts {
    margin-top: 1.5rem;
    border-top: 1px solid var(--glass-border);
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .fact-item {
    display: flex;
    gap: 1rem;
    font-size: 0.95rem;
  }

  .fact-item strong {
    width: 120px;
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .fact-item span {
    color: var(--text-main);
  }

  .details-sidebar {
    padding: 2.5rem;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .details-sidebar h3 {
    font-size: 1.5rem;
    color: var(--text-main);
  }

  .details-sidebar p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .booking-btn {
    width: 100%;
    height: 48px;
  }

  /* Gallery Section */
  .property-gallery {
    padding: 2rem 2rem 6rem 2rem;
  }

  /* Contact Section */
  .property-contact {
    padding: 2rem 2rem 8rem 2rem;
  }

  .contact-grid {
    padding: 2.5rem;
    border-radius: 12px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .contact-item h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gold);
    margin-bottom: 0.8rem;
  }

  .contact-item p {
    color: var(--text-main);
    font-size: 0.95rem;
  }

  .contact-item a {
    color: var(--text-main);
    transition: var(--transition-fast);
  }

  .contact-item a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .details-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
