---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, LANGUAGES } from '../../utils/i18n.js';
import Gallery from '../../components/Gallery.astro';

export function getStaticPaths() {
  return LANGUAGES.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = getTranslations(lang);

const galleryImages = [
  "/images/uploads/2023/05/casa-isabella-home.jpg",
  "/images/uploads/2023/05/casa-isabella-01-10.jpg",
  "/images/uploads/2023/05/casa-isabella-01-01.jpg",
  "/images/uploads/2023/05/casa-isabella-01-02.jpg",
  "/images/uploads/2023/05/casa-isabella-01-03.jpg",
  "/images/uploads/2023/05/casa-isabella-01-04.jpg",
