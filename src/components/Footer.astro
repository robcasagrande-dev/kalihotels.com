---
import { getTranslations } from '../utils/i18n.js';

const { lang } = Astro.props;
const t = getTranslations(lang);
---
<footer class="footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <img src="https://kalihotels.com/wp-content/uploads/2023/05/logo-kali-hotels-white.png" alt="Kali Hotels Logo" class="footer-logo" />
      <p class="footer-tagline">Three exclusive sanctuaries in the Colombian Caribbean.</p>
    </div>

    <div class="footer-links">
      <h4 class="footer-heading">Santuarios</h4>
      <ul>
        <li><a href={`/${lang}/#maria`}>{t.nav.villa_maria}</a></li>
        <li><a href={`/${lang}/#leda`}>{t.nav.casa_leda}</a></li>
        <li><a href={`/${lang}/#isabella`}>{t.nav.casa_isabella}</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <h4 class="footer-heading">Contact</h4>
      <p>Centro Histórico, Santa Marta, Colombia</p>
      <p>Email: <a href="mailto:info@kalihotels.com" class="footer-email">info@kalihotels.com</a></p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-container">
      <p class="copyright">{t.footer.copyright}</p>
      <div class="footer-socials">
        <a href="https://instagram.com/kalihotels" target="_blank" rel="noopener noreferrer" aria-label="Instagram">Instagram</a>
        <a href="https://facebook.com/kalihotels" target="_blank" rel="noopener noreferrer" aria-label="Facebook">Facebook</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #07080a;
    border-top: 1px solid var(--glass-border);
    padding-top: 4rem;
    margin-top: auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-logo {
    height: 48px;
    width: auto;
    align-self: flex-start;
    object-fit: contain;
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 320px;
  }

  .footer-heading {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    color: var(--text-main);
    letter-spacing: 0.05em;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--text-main);
    padding-left: 4px;
  }

  .footer-contact {
    color: var(--text-muted);
    font-size: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .footer-email {
    color: var(--color-gold);
  }

  .footer-email:hover {
    color: var(--text-main);
  }

  .footer-bottom {
    border-top: 1px solid var(--glass-border);
    padding: 2rem 0;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-socials {
    display: flex;
    gap: 1.5rem;
  }

  .footer-socials a {
    transition: var(--transition-fast);
  }

  .footer-socials a:hover {
    color: var(--text-main);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-bottom: 2.5rem;
    }
    
    .footer-bottom-container {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
