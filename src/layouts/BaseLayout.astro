---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { 
  title, 
  description = "Kali Hotels - Santa Marta & Tayrona", 
  lang = "es",
  ogImage = "https://kalihotels.com/wp-content/uploads/2024/04/VILLA-MARIA-DRONE-18-1.jpg",
  ogType = "website",
  schema
} = Astro.props;

const origin = "https://kalihotels.com";

// Normalize pathname to ensure leading and trailing slash
let pathname = Astro.url.pathname;
if (!pathname.startsWith('/')) {
  pathname = '/' + pathname;
}
if (!pathname.endsWith('/')) {
  pathname = pathname + '/';
}

// Extract path without language prefix to build alternates
const pathSegments = pathname.split('/').filter(Boolean); // e.g. ['en', 'villa-maria']
const innerPath = pathSegments.slice(1).join('/'); // 'villa-maria' or ''

// Build canonical URL
const canonicalURL = `${origin}${pathname}`;

// Build alternate links
const alternates = [
  { lang: 'es', href: `${origin}/es/${innerPath ? innerPath + '/' : ''}` },
  { lang: 'en', href: `${origin}/en/${innerPath ? innerPath + '/' : ''}` },
  { lang: 'it', href: `${origin}/it/${innerPath ? innerPath + '/' : ''}` },
  { lang: 'x-default', href: `${origin}/es/${innerPath ? innerPath + '/' : ''}` }
];
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="https://kalihotels.com/wp-content/uploads/2023/08/cropped-favicon-32x32.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Multilingual Alternate Links (hreflang) -->
    {alternates.map(alt => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Kali Hotels" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : lang === 'it' ? 'it_IT' : 'en_US'} />
    {lang !== 'es' && <meta property="og:locale:alternate" content="es_ES" />}
    {lang !== 'en' && <meta property="og:locale:alternate" content="en_US" />}
    {lang !== 'it' && <meta property="og:locale:alternate" content="it_IT" />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data (JSON-LD) -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="site-wrapper">
      <Header lang={lang} />
      <slot />
      <Footer lang={lang} />
    </div>
  </body>
</html>

<style>
  .site-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--bg-color);
  }
</style>
